<Window x:Class="Ex07.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ex07"
        mc:Ignorable="d"
        Title="Exercice 07 : Interface avec agencement avancé " Height="450" Width="800">
    <DockPanel>
        
        <!-- Menu en haut -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Fichier">
                <MenuItem Header="Ouvrir"/>
                <Separator/>
                <MenuItem Header="Quitter"/>
            </MenuItem>
            <MenuItem Header="Édition">
                <MenuItem Header="Copier"/>
                <MenuItem Header="Coller"/>
            </MenuItem>
            <MenuItem Header="Aide">
                <MenuItem Header="À propos"/>
            </MenuItem>
        </Menu>

        <!-- Barre latérale gauche -->
        <StackPanel DockPanel.Dock="Left" Width="130"
                    Background="#2D2D2D" Margin="0">
            <Label Content="Navigation" Foreground="White"
                   FontWeight="Bold" Margin="10,15,10,5"/>
            <Button Content="Accueil"   Margin="10,4" Padding="8,5"
                    Background="#3E3E3E" Foreground="White" BorderThickness="0"/>
            <Button Content="Utilisateurs" Margin="10,4" Padding="8,5"
                    Background="#3E3E3E" Foreground="White" BorderThickness="0"/>
            <Button Content="Rapports"  Margin="10,4" Padding="8,5"
                    Background="#3E3E3E" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <!-- Zone centrale : ListView -->
        <Border Padding="15" Background="White">
            <ListView>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nom"   Width="160"
                                        DisplayMemberBinding="{Binding Nom}"/>
                        <GridViewColumn Header="Âge"   Width="80"
                                        DisplayMemberBinding="{Binding Age}"/>
                        <GridViewColumn Header="Ville" Width="160"
                                        DisplayMemberBinding="{Binding Ville}"/>
                    </GridView>
                </ListView.View>

                <!-- Données fictives -->
               
            </ListView>
        </Border>
        
    </DockPanel>
</Window>
