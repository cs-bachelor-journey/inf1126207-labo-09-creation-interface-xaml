<Window x:Class="Ex04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ex04"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Exercice 04 — ListBox et ComboBox" Height="450" Width="800">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <Label Content="Pays: " FontWeight="Bold"/>
        <ComboBox Margin="0,0,0,15">
            <ComboBoxItem Content="France"/>
            <ComboBoxItem Content="Canada" IsSelected="True"/>
            <ComboBoxItem Content="USA"/>
        </ComboBox>

        <Label Content="Centre d'intérêt: " FontWeight="Bold"/>
        <ListBox>
            <ListBoxItem Content="Sport"/>
            <ListBoxItem Content="Musique"/>
            <ListBoxItem Content="Lecture"/>
        </ListBox>

        <Button Content="Valider"
                Margin="0,15,0,0"
                Padding="15,8" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
